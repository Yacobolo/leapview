{
  "$defs": {
    "#APIVersion": {
      "const": "libredash.dev/v1"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "WorkspaceAgentPolicy"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "instructions": {
          "type": "string"
        },
        "tools": {
          "additionalProperties": false,
          "properties": {
            "allow": {
              "items": {
                "$ref": "#/$defs/%23ResourceID"
              },
              "type": "array"
            },
            "deny": {
              "items": {
                "$ref": "#/$defs/%23ResourceID"
              },
              "type": "array"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "enabled",
        "tools"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
