{
  "$defs": {
    "#APIVersion": {
      "const": "libredash.dev/v1"
    },
    "#FieldRef": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_]*$",
      "type": "string"
    },
    "#Identifier": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$",
      "type": "string"
    },
    "#Measure": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "expr": {
          "type": "string"
        },
        "expression": {
          "type": "string"
        },
        "format": {
          "type": "string"
        },
        "grain": {
          "$ref": "#/$defs/%23Identifier"
        },
        "grains": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "label": {
          "type": "string"
        },
        "table": {
          "$ref": "#/$defs/%23Identifier"
        },
        "time": {
          "$ref": "#/$defs/%23FieldRef"
        },
        "unit": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "#Metadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "name": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "owner": {
          "type": "string"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "title": {
          "type": "string"
        },
        "workspace": {
          "$ref": "#/$defs/%23ResourceID"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "#ModelTable": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "fields": {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "additionalProperties": false,
              "properties": {
                "description": {
                  "type": "string"
                },
                "expr": {
                  "type": "string"
                },
                "expression": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                },
                "type": {
                  "type": "string"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "grain": {
          "$ref": "#/$defs/%23Identifier"
        },
        "kind": {
          "type": "string"
        },
        "measures": {
          "additionalProperties": false,
          "patternProperties": {
            "^[A-Za-z_][A-Za-z0-9_]*$": {
              "$ref": "#/$defs/%23Measure"
            }
          },
          "type": "object"
        },
        "primaryKey": {
          "$ref": "#/$defs/%23Identifier"
        },
        "source": {
          "$ref": "#/$defs/%23ResourceID"
        },
        "sources": {
          "items": {
            "$ref": "#/$defs/%23ResourceID"
          },
          "type": "array"
        },
        "sql": {
          "type": "string"
        },
        "transform": {
          "additionalProperties": false,
          "properties": {
            "sql": {
              "type": "string"
            }
          },
          "type": "object"
        }
      },
      "required": [
        "primaryKey"
      ],
      "type": "object"
    },
    "#ResourceID": {
      "pattern": "^[A-Za-z_][A-Za-z0-9_.-]*$",
      "type": "string"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "apiVersion": {
      "$ref": "#/$defs/%23APIVersion"
    },
    "kind": {
      "const": "ModelTable"
    },
    "metadata": {
      "$ref": "#/$defs/%23Metadata"
    },
    "spec": {
      "$ref": "#/$defs/%23ModelTable"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
