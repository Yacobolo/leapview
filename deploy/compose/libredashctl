#!/usr/bin/env bash
set -euo pipefail

ROOT="${LIBREDASHCTL_ROOT:-$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)}"
DOCKER_BIN="${LIBREDASHCTL_DOCKER_BIN:-docker}"
DEPLOYMENT_ENV="$ROOT/deployment.env"
APP_ENV="$ROOT/libredash.env"
INITIAL_CREDENTIALS="$ROOT/initial-credentials.json"
ROLLBACK_ENV="$ROOT/rollback.env"
LOCK_FILE="$ROOT/.libredashctl.lock"
FALLBACK_LOCK_DIR="$ROOT/.libredashctl.lock.d"

fail() { printf 'libredashctl: %s\n' "$*" >&2; exit 1; }
require_file() { [[ -s "$1" ]] || fail "required file is missing or empty: $1"; }
env_value() { awk -F= -v key="$1" '$1 == key {sub(/^[^=]*=/, ""); print; exit}' "$2"; }
require_digest() { [[ "$1" =~ ^[A-Za-z0-9._:/-]+@sha256:[0-9a-f]{64}$ ]] || fail "image must be pinned by digest"; }
random_hex() { openssl rand -hex 32; }
timestamp() { printf '%s-%s\n' "$(date -u +%Y%m%dT%H%M%SZ)" "$$"; }
sha256_file() {
  if command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | awk '{print $1}'; else shasum -a 256 "$1" | awk '{print $1}'; fi
}
unlock_fallback() { rmdir "$FALLBACK_LOCK_DIR" 2>/dev/null || true; }
lock() {
  if command -v flock >/dev/null 2>&1; then
    exec 9>"$LOCK_FILE"
    flock -n 9 || fail "another LibreDash operation is running"
    return
  fi
  if mkdir "$FALLBACK_LOCK_DIR" 2>/dev/null; then
    printf '%s\n' "$$" >"$FALLBACK_LOCK_DIR/pid"
  else
    local owner=""
    [[ -r "$FALLBACK_LOCK_DIR/pid" ]] && owner="$(<"$FALLBACK_LOCK_DIR/pid")"
    if [[ "$owner" =~ ^[0-9]+$ ]] && kill -0 "$owner" 2>/dev/null; then
      fail "another LibreDash operation is running"
    fi
    rm -f "$FALLBACK_LOCK_DIR/pid"
    rmdir "$FALLBACK_LOCK_DIR" 2>/dev/null || fail "another LibreDash operation is running"
    mkdir "$FALLBACK_LOCK_DIR" 2>/dev/null || fail "another LibreDash operation is running"
    printf '%s\n' "$$" >"$FALLBACK_LOCK_DIR/pid"
  fi
  trap 'rm -f "$FALLBACK_LOCK_DIR/pid"; unlock_fallback' EXIT
  trap 'exit 130' INT
  trap 'exit 143' TERM
}

compose() {
  require_file "$DEPLOYMENT_ENV"
  local files=(-f "$ROOT/compose.yaml")
  if [[ "$(env_value COMPOSE_HTTPS "$DEPLOYMENT_ENV")" == "1" ]]; then files+=(-f "$ROOT/compose.https.yaml"); fi
  "$DOCKER_BIN" compose --project-directory "$ROOT" --env-file "$DEPLOYMENT_ENV" "${files[@]}" "$@"
}

container_id() { compose ps -q libredash; }
is_running() { local id; id="$(container_id 2>/dev/null || true)"; [[ -n "$id" && "$($DOCKER_BIN inspect -f '{{.State.Running}}' "$id" 2>/dev/null || true)" == true ]]; }
wait_healthy() {
  local id status attempt=0; id="$(container_id)"; [[ -n "$id" ]] || return 1
  while (( attempt < 120 )); do
    attempt=$((attempt + 1))
    status="$($DOCKER_BIN inspect -f '{{.State.Health.Status}}' "$id" 2>/dev/null || true)"
    [[ "$status" == healthy ]] && return 0
    [[ "$status" == unhealthy ]] && break
    sleep 2
  done
  compose logs --tail=100 libredash >&2 || true
  return 1
}

capture_initial_credentials() {
  local tmp="$INITIAL_CREDENTIALS.tmp"
  rm -f "$tmp"
  if ! compose run --rm --no-deps libredash admin initialize --format json >"$tmp"; then
    rm -f "$tmp"
    fail "offline initialization did not deliver credentials; initialization can be retried"
  fi
  [[ -s "$tmp" ]] || { rm -f "$tmp"; fail "offline initialization returned empty credentials; initialization can be retried"; }
  chmod 0600 "$tmp"
  mv "$tmp" "$INITIAL_CREDENTIALS"
  if ! compose run --rm --no-deps libredash admin initialize --acknowledge-credentials; then
    fail "credentials were saved but acknowledgement failed; rerun init to complete initialization"
  fi
}

init_instance() {
  local admin="" domain="" environment="prod" https=1 image=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --admin-email) admin="$2"; shift 2 ;;
      --domain) domain="$2"; shift 2 ;;
      --environment) environment="$2"; shift 2 ;;
      --image) image="$2"; shift 2 ;;
      --no-https) https=0; shift ;;
      *) fail "unknown init argument: $1" ;;
    esac
  done
  [[ -n "$admin" ]] || fail "init requires --admin-email"
  [[ -n "$domain" ]] || fail "init requires --domain (the public host, including with an external proxy)"
  [[ -s "$DEPLOYMENT_ENV" ]] || cp "$ROOT/deployment.env.example" "$DEPLOYMENT_ENV"
  if [[ -s "$APP_ENV" && -s "$INITIAL_CREDENTIALS" ]]; then
    lock
    compose run --rm --no-deps libredash admin initialize --acknowledge-credentials
    printf 'initialization acknowledgement completed; run ./libredashctl start\n'
    return
  fi
  [[ ! -e "$APP_ENV" ]] || {
    lock
    capture_initial_credentials
    printf 'initialization completed; run ./libredashctl start\n'
    return
  }
  [[ ! -e "$INITIAL_CREDENTIALS" ]] || fail "credential file exists without instance configuration; move it aside before retrying"
  [[ -n "$image" ]] || image="$(env_value LIBREDASH_IMAGE "$DEPLOYMENT_ENV")"
  require_digest "$image"
  lock
  local tmp="$DEPLOYMENT_ENV.tmp"
  awk -F= -v image="$image" -v domain="$domain" -v https="$https" '
    $1=="LIBREDASH_IMAGE" {print "LIBREDASH_IMAGE=" image; next}
    $1=="CADDY_DOMAIN" {print "CADDY_DOMAIN=" domain; next}
    $1=="COMPOSE_HTTPS" {print "COMPOSE_HTTPS=" https; next}
    {print}
  ' "$DEPLOYMENT_ENV" >"$tmp" && chmod 0600 "$tmp" && mv "$tmp" "$DEPLOYMENT_ENV"
  require_digest "$(env_value CADDY_IMAGE "$DEPLOYMENT_ENV")"
  umask 077
  {
    printf 'LIBREDASH_PRODUCTION=1\nLIBREDASH_ENVIRONMENT=%s\nLIBREDASH_ADDR=:8080\n' "$environment"
    printf 'LIBREDASH_HOME=/var/lib/libredash/home\nLIBREDASH_MANAGED_DATA_BACKEND=local\nLIBREDASH_MANAGED_DATA_DIR=/var/lib/libredash/home/managed-data\n'
    printf 'LIBREDASH_LOCAL_AUTH=1\nLIBREDASH_COOKIE_SECURE=true\nLIBREDASH_TRUST_PROXY_HEADERS=true\n'
    printf 'LIBREDASH_ALLOWED_HOSTS=%s\nLIBREDASH_BOOTSTRAP_ADMIN_EMAIL=%s\n' "$domain" "$admin"
    printf 'LIBREDASH_CSRF_KEY=%s\nLIBREDASH_METRICS_BEARER_TOKEN=%s\n' "$(random_hex)" "$(random_hex)"
  } >"$APP_ENV"
  chmod 0600 "$APP_ENV"
  if ! compose pull libredash; then rm -f "$APP_ENV" "$INITIAL_CREDENTIALS"; fail "initial image pull failed; initialization can be retried"; fi
  if ! compose run --rm --no-deps libredash config validate --production; then rm -f "$APP_ENV" "$INITIAL_CREDENTIALS"; fail "configuration validation failed; initialization can be retried"; fi
  if ! compose config --quiet; then rm -f "$APP_ENV" "$INITIAL_CREDENTIALS"; fail "Compose configuration is invalid; initialization can be retried"; fi
  capture_initial_credentials
  printf 'initialized environment %s; run ./libredashctl start\n' "$environment"
}

start() { compose up -d; wait_healthy; }
status() { compose ps; local id; id="$(container_id)"; [[ -n "$id" ]] && "$DOCKER_BIN" exec "$id" libredash healthcheck; }
logs() { compose logs "${@:-libredash}"; }
first_login() { require_file "$INITIAL_CREDENTIALS"; umask 077; local value; value="$(<"$INITIAL_CREDENTIALS")"; printf '%s\n' "$value"; rm -f "$INITIAL_CREDENTIALS"; }

backup_archive() {
  local path="$1" directory tmp
  [[ ! -e "$path" ]] || return 1
  directory="$(dirname -- "$path")"
  mkdir -p "$directory"
  tmp="$(mktemp "$directory/.libredash-backup.XXXXXX")"
  if ! compose run --rm -T --no-deps libredash admin backup --out - >"$tmp"; then
    rm -f "$tmp"
    return 1
  fi
  if [[ ! -s "$tmp" ]]; then
    rm -f "$tmp"
    return 1
  fi
  chmod 0600 "$tmp"
  mv "$tmp" "$path"
}

backup() {
  lock
  local was_running=false name path backup_status=0
  if is_running; then was_running=true; fi
  if [[ "$was_running" == true ]]; then compose stop -t 120 libredash; fi
  name="${1:-libredash-$(timestamp).tar.gz}"; name="$(basename "$name")"; path="$ROOT/backups/$name"
  backup_archive "$path" || backup_status=$?
  if [[ "$backup_status" -eq 0 ]]; then sha256_file "$path" >"$path.sha256" || backup_status=$?; fi
  if [[ "$backup_status" -eq 0 ]]; then chmod 0600 "$path" "$path.sha256" || backup_status=$?; fi
  if [[ "$was_running" == true ]]; then start; fi
  [[ "$backup_status" -eq 0 ]] || fail "backup failed; the previous service state was restored"
  if [[ -n "${LIBREDASHCTL_BACKUP_HOOK:-}" ]]; then
    "$LIBREDASHCTL_BACKUP_HOOK" "$path"
  fi
  printf '%s\n' "$path"
}

restore_archive() {
  local archive="$1"
  compose run --rm -T --no-deps libredash admin restore --from - --current-out - --confirm <"$archive"
}

restore() {
  [[ $# -ge 1 ]] || fail "restore requires an archive"
  local archive="$1"; [[ -f "$archive" ]] || archive="$ROOT/backups/$(basename "$archive")"; [[ -f "$archive" ]] || fail "archive not found"
  lock
  if is_running; then compose stop -t 120 libredash; fi
  local before
  before="$ROOT/backups/pre-restore-$(timestamp).tar.gz"
  if ! backup_archive "$before"; then
    start || true
    fail "pre-restore backup failed; the previous service state was restarted"
  fi
  if ! restore_archive "$archive"; then
    restore_archive "$before" || true
    start || true
    fail "restore failed before health checking; the previous service state was restarted"
  fi
  if ! start; then
    compose stop -t 30 libredash || true
    restore_archive "$before"
    start || true
    fail "restored state failed health checks; previous state was reinstated"
  fi
}

set_image() {
  local image="$1" tmp="$DEPLOYMENT_ENV.tmp"
  awk -F= -v image="$image" '$1=="LIBREDASH_IMAGE" {print "LIBREDASH_IMAGE=" image; next} {print}' "$DEPLOYMENT_ENV" >"$tmp"
  chmod 0600 "$tmp" && mv "$tmp" "$DEPLOYMENT_ENV"
}

upgrade() {
  [[ $# -eq 1 ]] || fail "upgrade requires one image digest"; require_digest "$1"; lock
  local next="$1" current checkpoint
  current="$(env_value LIBREDASH_IMAGE "$DEPLOYMENT_ENV")"; require_digest "$current"; [[ "$next" != "$current" ]] || { printf 'already running %s\n' "$next"; return; }
  checkpoint="$ROOT/backups/pre-upgrade-$(timestamp).tar.gz"
  local was_running=false
  if is_running; then was_running=true; fi
  if [[ "$was_running" == true ]]; then compose stop -t 120 libredash; fi
  if ! backup_archive "$checkpoint"; then
    if [[ "$was_running" == true ]]; then start || true; fi
    fail "pre-upgrade backup failed; the previous service state was restored"
  fi
  printf 'PREVIOUS_IMAGE=%s\nCHECKPOINT=%s\n' "$current" "$checkpoint" >"$ROLLBACK_ENV"; chmod 0600 "$ROLLBACK_ENV"
  set_image "$next"
  if ! compose pull libredash; then
    set_image "$current"
    if [[ "$was_running" == true ]]; then start || true; fi
    fail "upgrade image pull failed; the previous image and service state were restored"
  fi
  if ! start; then
    compose stop -t 30 libredash || true; set_image "$current"
    restore_archive "$checkpoint"
    start || true; fail "upgrade failed; previous image and state were restored"
  fi
}

rollback() {
  [[ "${1:-}" == --confirm ]] || fail "rollback discards post-upgrade state; pass --confirm"
  require_file "$ROLLBACK_ENV"; lock
  local image checkpoint; image="$(env_value PREVIOUS_IMAGE "$ROLLBACK_ENV")"; checkpoint="$(env_value CHECKPOINT "$ROLLBACK_ENV")"
  require_digest "$image"; [[ -f "$checkpoint" ]] || fail "rollback checkpoint is missing"
  if is_running; then compose stop -t 120 libredash; fi
  local before="$ROOT/backups/pre-rollback-$(timestamp).tar.gz"
  backup_archive "$before" || fail "pre-rollback backup failed; rollback was not started"
  set_image "$image"; restore_archive "$checkpoint"; start
}

usage() { printf '%s\n' 'Usage: libredashctl init|start|status|logs|first-login|backup|restore|upgrade|rollback'; }
command="${1:-help}"; [[ $# -eq 0 ]] || shift
case "$command" in
  init) init_instance "$@";; start) start || fail "LibreDash did not become healthy";; status) status;; logs) logs "$@";; first-login) first_login;;
  backup) backup "$@";; restore) restore "$@";; upgrade) upgrade "$@";; rollback) rollback "$@";;
  help|-h|--help) usage;; *) fail "unknown command: $command";;
esac
